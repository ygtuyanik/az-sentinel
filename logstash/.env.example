# Azure AD App Registration (tüm pipeline'lar için ortak)
CLIENT_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_APP_SECRET=your-client-secret-here
TENANT_ID=92dd429a-2afb-438b-94d4-481f20a06fc5

# Data Collection Endpoint (tüm pipeline'lar için ortak, DCE'den alınır)
DCE_ENDPOINT=https://<dce-name>.westeurope.ingest.monitor.azure.com

# CEF kaynakları (Palo Alto, Imperva, vb.) → CommonSecurityLog
CEF_DCR_IMMUTABLE_ID=dcr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CEF_DCR_STREAM_NAME=Custom-CEFStream

# Syslog → Microsoft-Syslog (Syslog tablosu)
SYSLOG_DCR_IMMUTABLE_ID=dcr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SYSLOG_DCR_STREAM_NAME=Custom-SyslogStream
